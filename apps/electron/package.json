{
  "name": "@opentomo/electron",
  "version": "0.1.0",
  "description": "OpenTomo desktop app",
  "main": "dist/main.cjs",
  "private": true,
  "author": {
    "name": "OpenTomo Contributors"
  },
  "homepage": "https://github.com/OpenTomo/opentomo",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:main": "bun run ../../scripts/electron-build-main.ts",
    "build:main:win": "bun run ../../scripts/electron-build-main.ts",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --outfile=dist/preload.cjs --external:electron",
    "build:renderer": "vite build",
    "build:copy": "bun scripts/copy-assets.ts",
    "build": "bun run lint && bun run build:main && bun run build:preload && bun run build:renderer && bun run build:copy",
    "build:win": "bun run build:main:win && bun run build:preload && bun run build:renderer && bun run build:copy",
    "start": "bun run build && electron .",
    "start:win": "bun run build:win && electron .",
    "dev": "vite dev",
    "typecheck": "tsc --noEmit",
    "dist:mac": "bash scripts/build-dmg.sh arm64",
    "dist:mac:both": "bash scripts/build-dmg.sh arm64 && bash scripts/build-dmg.sh x64",
    "dist:mac:x64": "bash scripts/build-dmg.sh x64",
    "dist:win": "powershell -ExecutionPolicy Bypass -File scripts/build-win.ps1",
    "build:minimal": "CUSTOM_MODELS_CONFIG=build-configs/models-minimal.json bun run build",
    "build:premium": "CUSTOM_MODELS_CONFIG=build-configs/models-premium.json bun run build",
    "dist:mac:minimal": "CUSTOM_MODELS_CONFIG=build-configs/models-minimal.json bun run build && bun run dist:mac",
    "dist:mac:premium": "CUSTOM_MODELS_CONFIG=build-configs/models-premium.json bun run build && bun run dist:mac",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@paper-design/shaders-react": "^0.0.69",
    "@pierre/diffs": "^1.0.4",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-table": "^8.21.3",
    "@opentomo/core": "workspace:*",
    "@opentomo/shared": "workspace:*",
    "@opentomo/ui": "workspace:*",
    "cmdk": "^1.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.0",
    "jotai-family": "^1.0.1",
    "motion": "^12.23.26",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "5.4.296",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^10.3.0",
    "react-simple-code-editor": "^0.14.1",
    "remark": "^15.0.1",
    "sonner": "^2.0.7",
    "strip-markdown": "^6.0.0"
  },
  "devDependencies": {}
}
