{
  "name": "opentomo",
  "version": "0.1.0",
  "description": "OpenTomo - Open-source AI agent desktop app",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "!apps/online-docs"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "cd packages/shared && bun run tsc --noEmit",
    "typecheck:all": "cd packages/core && bun run tsc --noEmit && cd ../shared && bun run tsc --noEmit",
    "lint:electron": "cd apps/electron && bun run lint",
    "lint:shared": "cd packages/shared && npx eslint .",
    "lint": "bun run lint:electron && bun run lint:shared",
    "link": "bun link",
    "electron:clean": "bun run scripts/electron-clean.ts",
    "electron:build:main": "bun run scripts/electron-build-main.ts",
    "electron:build:preload": "bun run scripts/electron-build-preload.ts",
    "electron:build:renderer": "bun run scripts/electron-build-renderer.ts",
    "electron:build:resources": "bun run scripts/electron-build-resources.ts",
    "electron:build:assets": "bun run scripts/electron-build-assets.ts",
    "electron:stage-deps": "bun run scripts/electron-stage-sdk-deps.ts",
    "electron:build": "bun run electron:build:main && bun run electron:build:preload && bun run electron:build:renderer && bun run electron:build:resources && bun run electron:build:assets && bun run electron:stage-deps",
    "electron:start": "bun run electron:build && electron apps/electron",
    "electron:rebuild-native": "electron-rebuild -w better-sqlite3 --electronVersion 39.5.2 --projectRootPath apps/electron",
    "electron:dev": "bun run scripts/electron-dev.ts",
    "electron:dev:terminal": "bun run scripts/electron-dev.ts --terminal",
    "electron:dev:menu": "bash scripts/electron-dev.sh",
    "electron:dev:logs": "pgrep -f 'tail -f.*opentomo/main.log' > /dev/null || osascript -e \"tell application \\\"Terminal\\\" to do script \\\"$PWD/scripts/tail-electron-logs.sh\\\"\"",
    "sync-secrets": "bash scripts/sync-secrets.sh",
    "fresh-start": "bun run scripts/fresh-start.ts",
    "fresh-start:token": "bun run scripts/fresh-start.ts --token-only",
    "print:system-prompt": "bun run packages/shared/src/prompts/print-system-prompt.ts",
    "icons:generate": "bun run scripts/generate-all-icons.ts",
    "electron:dist": "bun run electron:build && cd apps/electron && electron-builder",
    "electron:dist:mac": "cd apps/electron && bun run dist:mac",
    "electron:dist:win": "bun run electron:build && cd apps/electron && electron-builder --win",
    "electron:dist:linux": "bun run electron:build && cd apps/electron && electron-builder --linux",
    "docs:dev": "cd apps/online-docs && npm install && npx mintlify dev",
    "build": "bun run scripts/build.ts",
    "release": "bun run scripts/release.ts",
    "check-version": "bun run scripts/check-version.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "@rollup/rollup-win32-arm64-msvc": "^4.55.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/bun": "latest",
    "@types/linkify-it": "^5.0.0",
    "@types/node": "^25.0.8",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.0.0",
    "vite": "^6.2.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "bash-parser": "^0.5.0",
    "glob": "^11.0.0",
    "incr-regex-package": "^1.0.4",
    "open": "^10.1.0",
    "tar": "^7.4.3",
    "@anthropic-ai/sdk": "^0.71.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "i18next": "^25.8.4",
    "jotai": "^2.16.0",
    "linkify-it": "^5.0.0",
    "lucide-react": "^0.561.0",
    "markitdown-js": "^0.0.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.19.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.0.0"
  }
}
